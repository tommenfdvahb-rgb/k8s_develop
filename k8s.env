#MASTERS配置例如：MASTERS=192.168.3.213,192.168.3.213
MASTERS=
#NODES配置例如：NODES=192.168.3.214,192.168.3.217,192.168.3.224
NODES=
#SSH登录密码（如果使用密钥登录则留空）
PASSWORD=
#SSH端口，默认为22
PORT=22
#登录用户，默认为root
SSH_USER=root

# Rancher(可选)
SKIP_RANCHER=1
# RANCHER_HOSTNAME=rancher.local
# RANCHER_NAMESPACE=cattle-system
# RANCHER_CHART_DIR=